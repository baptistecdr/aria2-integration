{
  "name": "aria2-integration",
  "private": true,
  "type": "module",
  "version": "4.14.1-SNAPSHOT.0",
  "scripts": {
    "lint": "biome check",
    "lint:fix": "biome check --fix --unsafe",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build:firefox": "tsc && vite build --emptyOutDir --mode firefox",
    "build:firefox:debug": "tsc && vite build --mode firefox-debug --emptyOutDir",
    "build:firefox:debug:watch": "tsc && vite build --mode firefox-debug --emptyOutDir --watch",
    "start:firefox": "web-ext run --source-dir ./dist/ --devtools",
    "start:firefox:android": "web-ext run --source-dir ./dist/ -t firefox-android --adb-device $(adb devices | awk 'NR > 1 && $2 == \"device\" { print $1; exit }') --firefox-apk org.mozilla.firefox",
    "build:chromium": "tsc && vite build --emptyOutDir --mode chromium",
    "build:chromium:debug": "tsc && vite build --mode chromium-debug --emptyOutDir",
    "build:chromium:debug:watch": "tsc && vite build --mode chromium-debug --emptyOutDir --watch",
    "start:chromium": "web-ext run --source-dir ./dist/ -t chromium --devtools"
  },
  "dependencies": {
    "@baptistecdr/aria2": "7.0.0",
    "@stdlib/regexp-basename-posix": "0.2.3",
    "@stdlib/regexp-basename-windows": "0.2.4",
    "@stdlib/regexp-dirname-posix": "0.2.2",
    "@stdlib/regexp-dirname-windows": "0.2.2",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "filesize": "11.0.19",
    "luxon": "3.7.2",
    "path": "0.12.7",
    "react": "19.2.7",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.7",
    "uuid": "14.0.1",
    "webextension-polyfill": "0.12.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bootstrap": "5.2.11",
    "@types/jest": "30.0.0",
    "@types/luxon": "3.7.2",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "memfs": "4.57.8",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "web-ext": "10.4.0"
  }
}
