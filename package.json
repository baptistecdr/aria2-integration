{
  "name": "aria2-integration",
  "private": true,
  "type": "module",
  "version": "4.13.4-SNAPSHOT.0",
  "scripts": {
    "lint": "biome check",
    "lint:fix": "biome check --fix --unsafe",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build:firefox": "tsc && vite build --emptyOutDir --mode firefox",
    "build:firefox:debug": "tsc && vite build --mode firefox-debug --emptyOutDir",
    "build:firefox:debug:watch": "tsc && vite build --mode firefox-debug --emptyOutDir --watch",
    "start:firefox": "web-ext run --source-dir ./dist/ --devtools",
    "build:chromium": "tsc && vite build --emptyOutDir --mode chromium",
    "build:chromium:debug": "tsc && vite build --mode chromium-debug --emptyOutDir",
    "build:chromium:debug:watch": "tsc && vite build --mode chromium-debug --emptyOutDir --watch",
    "start:chromium": "web-ext run --source-dir ./dist/ -t chromium --devtools"
  },
  "dependencies": {
    "@baptistecdr/aria2": "5.1.2",
    "@stdlib/regexp-basename-posix": "0.2.3",
    "@stdlib/regexp-basename-windows": "0.2.4",
    "@stdlib/regexp-dirname-posix": "0.2.2",
    "@stdlib/regexp-dirname-windows": "0.2.2",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "filesize": "11.0.15",
    "luxon": "3.7.2",
    "path": "0.12.7",
    "react": "19.2.5",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.5",
    "uuid": "13.0.0",
    "webextension-polyfill": "0.12.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bootstrap": "5.2.10",
    "@types/jest": "30.0.0",
    "@types/luxon": "3.7.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.4",
    "jsdom": "29.0.2",
    "memfs": "4.57.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-node-polyfills": "0.26.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4",
    "web-ext": "10.1.0"
  }
}
